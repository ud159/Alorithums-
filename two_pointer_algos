#include <bits/stdc++.h>
using namespace std;

pair<int,int> twoSumSorted(vector<int>& a, int target) {
    int l = 0;
    int r = a.size() - 1;

    while(l < r) {
        int sum = a[l] + a[r];

        if(sum == target) return {l, r};
        else if(sum < target) l++;
        else r--;
    }

    return {-1,-1};
}


//remove duplicate in sorted array
int removeDuplicates(vector<int>& a) {
    if(a.empty()) return 0;

    int j = 0;

    for(int i = 1; i < a.size(); i++) {
        if(a[i] != a[j]) {
            j++;
            a[j] = a[i];
        }
    }

    return j + 1;
}


