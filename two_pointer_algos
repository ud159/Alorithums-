//subarray with k distinct elemets
int atMostK(vector<int>& a, int k) {

    unordered_map<int,int> mp;
    int l = 0;
    long long count = 0;

    for (int r = 0; r < a.size(); r++) {

        mp[a[r]]++;

        while (mp.size() > k) {
            mp[a[l]]--;
            if (mp[a[l]] == 0)
                mp.erase(a[l]);
            l++;
        }

        count += r - l + 1;
    }

    return count;
}

